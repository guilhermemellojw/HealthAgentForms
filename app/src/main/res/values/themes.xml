<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main application theme -->
    <style name="Theme.HealthAgentForms" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash Screen theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/app_background_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_3d_vigilancia_inset</item>
        <item name="postSplashScreenTheme">@style/Theme.HealthAgentForms</item>
    </style>
</resources>
